# ============================================
# NovaPlan Environment Variables
# Copy to .env.local and fill in the values
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key

# Midtrans Payment (Sandbox)
MIDTRANS_SERVER_KEY_SANDBOX=your_midtrans_server_key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY_SANDBOX=your_midtrans_client_key

# Resend Email
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000