# ============================================
# NovaPlan Environment Variables
# Copy to .env.local and fill in the values
# ============================================

# InsForge
NEXT_PUBLIC_INSFORGE_URL=https://4ew2z6h5.ap-southeast.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_key
INSFORGE_API_KEY=your_api_key

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key

# Midtrans Payment (Sandbox)
MIDTRANS_SERVER_KEY_SANDBOX=your_midtrans_server_key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY_SANDBOX=your_midtrans_client_key

# Resend Email (for feedback notifications)
RESEND_API_KEY=your_resend_api_key
FEEDBACK_EMAIL=your@email.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry Monitoring (Fase 9+)
# Get from https://sentry.io/organizations/novaplan/settings/projects/novaplan-ai/keys/
SENTRY_DSN=https://xxxx@sentry.io/xxxx
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=novaplan

# Vercel Analytics (auto-configured on Vercel deployment)
# VERCEL_GIT_COMMIT_SHA (auto-set by Vercel)